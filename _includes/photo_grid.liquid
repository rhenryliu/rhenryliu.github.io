{%- comment -%}
  _includes/photo_grid.liquid

  Shared square photo grid for the Photography section. This file is ADDED by the
  site (it is not part of the al-folio gem and does not override a gem include),
  so it is upgrade-safe. All styling and the click-to-zoom lightbox are contained
  here — no gem _layouts/_includes/_sass and no _config.yml changes are involved.

  Two modes, selected by the `mode` parameter:

    {% include photo_grid.liquid mode="tiles" %}
        Renders page.categories as square cover tiles with the category name
        overlaid, each linking to /photography/<slug>/. Used on the landing page.

    {% include photo_grid.liquid mode="gallery" %}
        Renders page.photos as square-cropped thumbnails. Clicking a thumbnail
        opens a self-contained lightbox that shows the FULL-RESOLUTION original
        at its true aspect ratio, with any caption in a strip below the image.
        (This gallery deliberately does NOT use the theme's medium-zoom, which
        reused the cropped thumbnail element and distorted the opened image.)

  Expected front-matter shapes:

    categories:
      - slug: nature
        title: Nature
        cover: assets/img/photography/nature/cover.jpg

    photos:
      - path: assets/img/photography/nature/01.jpg
        caption: Optional caption            # caption is optional
{%- endcomment -%}

<style>
  /* Grid: 1 column on phones, 2 on tablets, 3 on desktop */
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  @media (min-width: 576px) { .photo-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 992px) { .photo-grid { grid-template-columns: repeat(3, 1fr); } }

  .photo-cell {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 0.4rem;
    background: var(--global-code-bg-color, #eaeaea);
  }
  /* figure.liquid nests <figure><picture><img>; make them fill the square cell.
     NOTE: this square-crop only ever applies to thumbnails — the lightbox uses a
     separate <img> (.pg-lb-img) that these rules never touch. */
  .photo-cell figure,
  .photo-cell picture { display: block; width: 100%; height: 100%; margin: 0; }
  .photo-cell img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  /* --- tiles (landing page) --- */
  a.photo-cell { text-decoration: none; }
  a.photo-cell:hover img { transform: scale(1.06); }
  .photo-tile-title {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 0.9rem 0.75rem 0.6rem;
    color: #fff;
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.2;
    text-align: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0));
    pointer-events: none;
  }

  /* --- gallery thumbnails (category page) --- */
  .photo-cell.photo-zoom { cursor: zoom-in; padding: 0; border: 0; }
  .photo-cell.photo-zoom:hover img { transform: scale(1.05); }
  .photo-cell.photo-zoom:focus-visible { outline: 2px solid var(--global-theme-color, #b509ac); outline-offset: 2px; }
  /* Caption shown on the thumbnail, revealed on hover/keyboard focus. */
  .photo-caption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 0.6rem 0.5rem 0.4rem;
    color: #fff;
    font-size: 0.8rem;
    text-align: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none; /* clicks pass through to the cell so the lightbox opens */
  }
  .photo-cell.photo-zoom:hover .photo-caption,
  .photo-cell.photo-zoom:focus-visible .photo-caption { opacity: 1; }

  /* --- lightbox (full-resolution zoom view) --- */
  .pg-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.92);
  }
  .pg-lightbox[hidden] { display: none; }
  .pg-lb-figure {
    margin: 0;
    max-width: 100%;
    text-align: center;
  }
  .pg-lb-img {
    display: block;
    margin: 0 auto;
    width: auto;
    height: auto;
    max-width: 100%;
    /* No caption: use nearly the whole viewport height. */
    max-height: calc(100vh - 3rem);
    object-fit: contain;
    border-radius: 0.2rem;
    box-shadow: 0 0 45px rgba(0, 0, 0, 0.6);
  }
  /* Caption present: reserve a small strip below the photo for it. */
  .pg-lightbox.pg-has-cap .pg-lb-img { max-height: calc(100vh - 6.5rem); }
  .pg-lb-cap {
    margin: 0.75rem auto 0;
    max-width: 60ch;
    color: #eee;
    font-size: 0.9rem;
    line-height: 1.4;
    text-align: center;
  }
  .pg-lb-cap:empty { display: none; }
  .pg-lb-close {
    position: fixed;
    top: 0.75rem;
    right: 1.25rem;
    background: none;
    border: 0;
    color: #fff;
    font-size: 2.4rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
  }
  .pg-lb-close:hover { opacity: 1; }
  .pg-lb-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: 0;
    color: #fff;
    font-size: 3rem;
    line-height: 1;
    padding: 0 0.75rem;
    cursor: pointer;
    opacity: 0.7;
    user-select: none;
  }
  .pg-lb-nav:hover { opacity: 1; }
  .pg-lb-prev { left: 0.25rem; }
  .pg-lb-next { right: 0.25rem; }
</style>

{%- if include.mode == "tiles" -%}
  <div class="photo-grid">
  {%- for cat in page.categories -%}
    <a class="photo-cell" href="{{ '/photography/' | append: cat.slug | append: '/' | relative_url }}">
      {% include figure.liquid path=cat.cover class="photo-cover" loading="eager" %}
      <span class="photo-tile-title">{{ cat.title }}</span>
    </a>
  {%- endfor -%}
  </div>

{%- elsif include.mode == "gallery" -%}
  <div class="photo-grid">
  {%- for photo in page.photos -%}
    <div class="photo-cell photo-zoom" role="button" tabindex="0"
         data-full="{{ photo.path | relative_url }}"
         {%- if photo.caption %} data-caption="{{ photo.caption | escape }}" aria-label="View photo: {{ photo.caption | escape }}"{% else %} aria-label="View photo"{% endif %}>
      {% include figure.liquid path=photo.path class="photo-thumb" %}
      {%- if photo.caption -%}<span class="photo-caption">{{ photo.caption }}</span>{%- endif -%}
    </div>
  {%- endfor -%}
  </div>

  <div class="pg-lightbox" id="pg-lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true">
    <button type="button" class="pg-lb-close" aria-label="Close">&times;</button>
    <button type="button" class="pg-lb-nav pg-lb-prev" aria-label="Previous photo">&#8249;</button>
    <button type="button" class="pg-lb-nav pg-lb-next" aria-label="Next photo">&#8250;</button>
    <figure class="pg-lb-figure">
      <img class="pg-lb-img" src="" alt="" />
      <figcaption class="pg-lb-cap"></figcaption>
    </figure>
  </div>

  <script>
    (function () {
      var lb = document.getElementById("pg-lightbox");
      if (!lb) return;
      var lbImg = lb.querySelector(".pg-lb-img");
      var lbCap = lb.querySelector(".pg-lb-cap");
      var closeBtn = lb.querySelector(".pg-lb-close");
      var prevBtn = lb.querySelector(".pg-lb-prev");
      var nextBtn = lb.querySelector(".pg-lb-next");
      var cells = Array.prototype.slice.call(document.querySelectorAll(".photo-cell.photo-zoom"));
      if (!cells.length) return;
      var current = -1;
      var lastFocused = null;

      function show(i) {
        if (i < 0 || i >= cells.length) return; // no wraparound: ignore moves past either end
        current = i;
        var cell = cells[current];
        var cap = cell.getAttribute("data-caption") || "";
        lbImg.src = cell.getAttribute("data-full");
        lbImg.alt = cap;
        lbCap.textContent = cap;
        lb.classList.toggle("pg-has-cap", cap.length > 0);
        // Hide the arrow at whichever end we're on (both hidden for a single photo).
        prevBtn.hidden = current === 0;
        nextBtn.hidden = current === cells.length - 1;
      }

      function open(i) {
        lastFocused = cells[i] || null;
        show(i);
        lb.hidden = false;
        lb.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
        closeBtn.focus();
      }

      function close() {
        lb.hidden = true;
        lb.setAttribute("aria-hidden", "true");
        lbImg.src = "";
        document.body.style.overflow = "";
        if (lastFocused) { lastFocused.focus(); lastFocused = null; }
      }

      cells.forEach(function (cell, i) {
        cell.addEventListener("click", function () { open(i); });
        cell.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(i); }
        });
      });

      closeBtn.addEventListener("click", close);
      prevBtn.addEventListener("click", function () { show(current - 1); });
      nextBtn.addEventListener("click", function () { show(current + 1); });
      // Click on the dark backdrop (not the image, caption, or a button) closes.
      lb.addEventListener("click", function (e) { if (e.target === lb) close(); });
      document.addEventListener("keydown", function (e) {
        if (lb.hidden) return;
        if (e.key === "Escape") close();
        else if (e.key === "ArrowLeft") { e.preventDefault(); show(current - 1); }
        else if (e.key === "ArrowRight") { e.preventDefault(); show(current + 1); }
      });
    })();
  </script>
{%- endif -%}
